{
  "name": "spectra-drift",
  "version": "0.1.0",
  "description": "A personal Spotify-adjacent desktop audio visualizer.",
  "main": "out/main/index.js",
  "type": "module",
  "private": true,
  "scripts": {
    "build:native": "swift build -c release --package-path native/system-audio-helper && mkdir -p native/bin && cp native/system-audio-helper/.build/release/SystemAudioHelper native/bin/SystemAudioHelper",
    "dev": "npm run build:native && electron-vite dev",
    "dev:renderer": "vite --host 127.0.0.1 --config vite.renderer.config.ts",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "npm run build && playwright test",
    "build": "npm run build:native && npm run typecheck && electron-vite build"
  },
  "dependencies": {
    "@vitejs/plugin-react": "^5.0.0",
    "lucide-react": "^0.468.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "three": "^0.171.0"
  },
  "devDependencies": {
    "@electron-toolkit/utils": "^3.0.0",
    "@eslint/js": "^9.17.0",
    "@playwright/test": "^1.49.1",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.1.0",
    "@testing-library/user-event": "^14.5.2",
    "@types/node": "^22.10.2",
    "@types/react": "^18.3.17",
    "@types/react-dom": "^18.3.5",
    "@types/three": "^0.171.0",
    "@vitest/coverage-v8": "^3.2.6",
    "electron": "^42.5.0",
    "electron-vite": "^3.0.0",
    "eslint": "^9.17.0",
    "eslint-plugin-react-hooks": "^5.1.0",
    "eslint-plugin-react-refresh": "^0.4.16",
    "globals": "^15.14.0",
    "jsdom": "^25.0.1",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.18.1",
    "vite": "^6.0.5",
    "vitest": "^3.2.6"
  },
  "build": {
    "appId": "dev.codex.spectra-drift",
    "productName": "Spectra Drift",
    "mac": {
      "category": "public.app-category.music",
      "extendInfo": {
        "NSMicrophoneUsageDescription": "Spectra Drift can use the microphone as an audio-reactive fallback source.",
        "NSScreenCaptureUsageDescription": "Spectra Drift can capture desktop audio for local real-time visualization."
      }
    }
  }
}
